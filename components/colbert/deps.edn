{:paths ["src" "resources"]
 :deps {com.brunobonacci/mulog {:mvn/version "0.9.0"}
        org.clojure/data.json {:mvn/version "2.5.1"}}
 :aliases {:test {:extra-paths ["test"]
                  ;; colbert's tests use the shared grain test harness, so the
                  ;; test classpath needs grain-test-utils. Declared here so
                  ;; `poly test brick:colbert` runs the brick in isolation
                  ;; rather than depending on the umbrella :dev alias.
                  :extra-deps {orc/grain-test-utils {:local/root "../grain-test-utils"}}}}}
