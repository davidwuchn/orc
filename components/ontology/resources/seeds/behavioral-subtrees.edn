     :good-when
     "input is a single large document AND extraction is per-chunk independent",
     :recommended-pattern
     "[:map-each {:items :chunks :as :chunk :max-concurrency 3 :writes [:per-chunk-extracts]} [:llm {:reads [:chunk] :writes [:per-chunk-extracts]}]]",
