     :good-when "downstream stage will pick one of the candidates",
     :recommended-pattern
     "[:llm {:reads [:goal] :writes [:options] :output-schemas {:options [:vector [:map [:option :string] [:rationale :string] [:tradeoff :string] [:risk :string]]]}}]",
