{:aliases {:dev {:extra-paths ["development/src" "development/bench"]
                 :jvm-opts ["--add-opens=java.base/java.nio=ALL-UNNAMED"
                            "--add-opens=java.base/sun.nio.ch=ALL-UNNAMED"]
                 :extra-deps {org.clojure/clojure {:mvn/version "1.12.0"}

                              obneyai/grain-core-v2 {:git/url "https://github.com/ObneyAI/grain.git"
                                                     :git/sha "0ab49d7fd3847ce5ec485d29a6fbe292ba4e7856"
                                                     :deps/root "projects/grain-core-v2"}

                              obneyai/grain-control-plane {:git/url "https://github.com/ObneyAI/grain.git"
                                                           :git/sha "0ab49d7fd3847ce5ec485d29a6fbe292ba4e7856"
                                                           :deps/root "projects/grain-control-plane"}

                              ;; Base
                              orc/orc-dev           {:local/root "bases/orc-dev"}

                              ;; Components
                              orc/orc-service       {:local/root "components/orc-service"}
                              orc/gepa              {:local/root "components/gepa"}
                              orc/evaluation        {:local/root "components/evaluation"}
                              orc/colbert           {:local/root "components/colbert"}
                              orc/ontology          {:local/root "components/ontology"}
                              orc/mcp-sheet-builder {:local/root "components/mcp-sheet-builder"}
                              orc/agent-browser     {:local/root "components/agent-browser"}
                              orc/langfuse          {:local/root "components/langfuse"}
                              orc/grain-test-utils  {:local/root "components/grain-test-utils"}
                              orc/predict-rlm-pdf   {:local/root "components/predict-rlm-pdf"}
                              orc/predict-rlm-image-tools {:local/root "components/predict-rlm-image-tools"}
                              orc/predict-rlm-redaction-tools {:local/root "components/predict-rlm-redaction-tools"}
                              orc/predict-rlm-invoice-tools {:local/root "components/predict-rlm-invoice-tools"}}}

           :test {:extra-paths ["components/orc-service/test"
                                "components/gepa/test"
                                "components/colbert/test"
                                "components/evaluation/test"
                                "components/ontology/test"
                                "components/mcp-sheet-builder/test"
                                "components/predict-rlm-pdf/test"
                                "components/predict-rlm-image-tools/test"
                                "components/predict-rlm-redaction-tools/test"
                                "components/predict-rlm-invoice-tools/test"]}

           :poly {:main-opts ["-m" "polylith.clj.core.poly-cli.core"]
                  :extra-deps {polylith/clj-poly {:mvn/version "0.2.22"}}
                  :jvm-opts ["--add-opens=java.base/java.nio=ALL-UNNAMED"
                             "--add-opens=java.base/sun.nio.ch=ALL-UNNAMED"]}}}
